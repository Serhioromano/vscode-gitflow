{
    "name": "vscode-gitflow",
    "displayName": "Git Flow",
    "description": "Git-Flow support for VS Code",
    "version": "1.5.1",
    "engines": {
        "vscode": "^1.73.0"
    },
    "l10n": "./l10n",
    "sponsor": {
        "url": "https://www.paypal.com/donate/?hosted_button_id=UTU4EMPLLLX54"
    },
    "publisher": "Serhioromano",
    "author": "Sergey Romanov",
    "preview": true,
    "keywords": [
        "git flow",
        "gitflow",
        "git-flow",
        "git",
        "flow",
        "github",
        "feature",
        "release",
        "bugfix",
        "bug fix",
        "hotfix",
        "hot fix",
        "support",
        "version",
        "version manager",
        "versions",
        "versioning",
        "DevOps",
        "CI/CD",
        "SCM"
    ],
    "categories": [
        "Other",
        "SCM Providers"
    ],
    "icon": "icon.drawio.png",
    "activationEvents": [
        "workspaceContains:.git"
    ],
    "extensionDependencies": [
        "vscode.git",
        "vscode.git-base"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Serhioromano/vscode-gitflow"
    },
    "homepage": "https://marketplace.visualstudio.com/items?itemName=serhioromano.vscode-gitflow",
    "contributes": {
        "configuration": {
            "title": "%gitflow.configuration.title%",
            "properties": {
                "gitflow.showNotification": {
                    "type": "boolean",
                    "default": true,
                    "description": "%gitflow.showNotification.description%"
                },
                "gitflow.showAllCommands": {
                    "type": "boolean",
                    "default": false,
                    "description": "%gitflow.showAllCommands.description%"
                },
                "gitflow.path": {
                    "type": "string",
                    "default": "",
                    "description": "%gitflow.path.description%"
                },
                "gitflow.replaceSymbol": {
                    "type": "string",
                    "default": "_",
                    "description": "%gitflow.replaceSymbol.description%"
                },
                "gitflow.autoBumpVersion": {
                    "type": "boolean",
                    "default": true,
                    "description": "%gitflow.autoBumpVersion.description%"
                },
                "gitflow.disableOnRepo": {
                    "type": "boolean",
                    "default": false,
                    "description": "%gitflow.disableOnRepo.description%"
                },
                "gitflow.usePowerShell": {
                    "type": "boolean",
                    "default": false,
                    "description": "%gitflow.usePowerShell.description%",
                    "scope": "machine-overridable"
                },
                "gitflow.variant": {
                    "type": "string",
                    "enum": ["auto", "avh"],
                    "default": "auto",
                    "description": "%gitflow.variant.description%"
                }
            }
        },
        "keybindings": [
            {
                "command": "gitflow.quickPick",
                "key": "shift+alt+d",
                "when": "gitflow.initialized == true"
            }
        ],
        "commands": [

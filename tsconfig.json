{
	"compilerOptions": {
		"module": "commonjs",
		"moduleResolution": "bundler",
		"target": "ES2020",
		"outDir": "out",
		"lib": [
			"ES2020"
		],
		"sourceMap": true,
		"rootDir": "src",
        "experimentalDecorators": true,
        "esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"exclude": [
		"node_modules",
		".vscode-test"
	]
}
